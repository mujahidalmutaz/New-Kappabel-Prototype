# Copy to .env and set a real Postgres connection string.
# Local example:
#   DATABASE_URL="postgresql://user:password@localhost:5432/kappabel?schema=public"
# Hosted (Neon / Vercel Postgres / Supabase) — use the pooled URL they provide:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
