// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH & USERS ─────────────────────────────
model User {
  id         Int     @id                     // explicit id (matches Employee.id for imported users)
  username   String  @unique
  password   String
  name       String
  role       String  // employee | manager | hr | hr_officer | hr_manager | od_officer | od_manager | superadmin
  dept       String  @default("")
  position   String  @default("")
  email      String  @default("")
  employeeId Int?                            // link to Employee.id
  salary     Int     @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  leaves   Leave[]
}

// ─── ORG STRUCTURE ────────────────────────────
// Enterprise → Division → Company → Business Unit → Department; Position lives under
// Department and references JobFamily + Grade. References use plain Int fields (with
// indexes) rather than enforced FKs, to keep the bulk import seed order-independent.
model Enterprise {
  id       Int     @id
  code     String  @default("")
  name     String
  country  String  @default("")
  industry String  @default("")
  status   String  @default("Active")
}

model Division {
  id           Int    @id
  enterpriseId Int?
  code         String @default("")
  name         String
  headName     String @default("")
  status       String @default("Active")

  @@index([enterpriseId])
}

model Company {
  id          Int    @id
  divisionId  Int?
  code        String @default("")
  companyCode String @default("")
  name        String
  legalEntity String @default("")
  country     String @default("")
  status      String @default("Active")

  @@index([divisionId])
}

model BusinessUnit {
  id         Int    @id
  companyId  Int?
  code       String @default("")
  name       String
  costCenter String @default("")
  status     String @default("Active")

  @@index([companyId])
}

model Department {
  id             Int    @id
  businessUnitId Int?
  code           String @default("")
  name           String
  status         String @default("Active")

  @@index([businessUnitId])
}

model JobFamily {
  id          Int    @id
  code        String @default("")
  name        String
  description String @default("")
  status      String @default("Active")
}

model Grade {
  id        Int    @id   // == Mercer PC
  code      String @default("")
  pc        Int
  name      String @default("")
  category  String @default("")
  minSalary Int    @default(0)
  maxSalary Int    @default(0)
}

model Position {
  id           Int    @id
  departmentId Int?
  jobFamilyId  Int?
  gradeId      Int?
  code         String @default("")
  name         String
  status       String @default("Active")

  @@index([departmentId])
  @@index([jobFamilyId])
}

// ─── EMPLOYEE ─────────────────────────────────
model Employee {
  id             Int     @id                 // explicit id (200001+ for imported)
  nik            String                      // Person Number (not unique: source has 1 dup)
  name           String
  status         String  @default("Active")
  // Employment / org placement
  companyId      Int?
  divisionId     Int?
  businessUnitId Int?
  departmentId   Int?
  positionId     Int?
  gradeId        Int?
  managerId      Int?                         // supervisor Employee.id
  employmentType String  @default("")
  role           String  @default("employee")
  joinDate       String  @default("")
  endDate        String  @default("")
  // Bio
  gender         String  @default("")
  birthPlace     String  @default("")
  birthDate      String  @default("")
  nationality    String  @default("")
  religion       String  @default("")
  maritalStatus  String  @default("")
  ktp            String  @default("")
  phone          String  @default("")
  email          String  @default("")
  personalEmail  String  @default("")
  address        String  @default("")
  city           String  @default("")
  province       String  @default("")
  country        String  @default("")
  location       String  @default("")
  // Legacy plain-text fields (demo compatibility)
  dept           String  @default("")
  position       String  @default("")
  salary         Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payroll     Payroll?
  assignments ScheduleAssignment[]
  attendance  Attendance[]

  @@index([nik])
  @@index([managerId])
  @@index([departmentId])
  @@index([companyId])
}

// ─── LEAVE ────────────────────────────────────
model LeaveType {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  maxDays     Int
  requireDoc  Boolean @default(false)
  levels      String  // JSON string: ["Manager","HR"]
  autoApprove Boolean @default(false)
  active      Boolean @default(true)

  leaves Leave[]
}

model Leave {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  typeId    Int
  leaveType LeaveType @relation(fields: [typeId], references: [id])
  typeName  String
  startDate String
  endDate   String
  note      String?
  status    String    @default("Pending") // Pending | Approved | Rejected
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── HOLIDAY ──────────────────────────────────
model Holiday {
  id        Int     @id @default(autoincrement())
  country   String
  name      String
  date      String
  type      String  @default("National") // National | Optional | Company
  recurring Boolean @default(false)
  createdAt DateTime @default(now())
}

// ─── SHIFT ────────────────────────────────────
model Shift {
  id         Int     @id @default(autoincrement())
  name       String
  code       String  @unique
  startTime  String
  endTime    String
  breakMins  Int     @default(60)
  color      String  @default("#3b82f6")
  type       String  @default("Regular") // Regular | Off | Flexible
  overnight  Boolean @default(false)
  createdAt  DateTime @default(now())
}

model ShiftPattern {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  days        String  // JSON: {"1":4,"2":4,...,"7":5} shiftId per day
  createdAt   DateTime @default(now())

  workSchedules WorkSchedule[]
}

model WorkSchedule {
  id            Int          @id @default(autoincrement())
  name          String
  patternId     Int
  pattern       ShiftPattern @relation(fields: [patternId], references: [id])
  effectiveDate String
  endDate       String?
  timezone      String       @default("WIB (UTC+7)")
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())

  assignments ScheduleAssignment[]
}

model ScheduleAssignment {
  id            Int          @id @default(autoincrement())
  empId         Int
  employee      Employee     @relation(fields: [empId], references: [id])
  wsId          Int
  workSchedule  WorkSchedule @relation(fields: [wsId], references: [id])
  effectiveDate String
  endDate       String?
  createdAt     DateTime     @default(now())
}

// ─── ATTENDANCE ───────────────────────────────
model Attendance {
  id       Int      @id @default(autoincrement())
  empId    Int
  employee Employee @relation(fields: [empId], references: [id])
  date     String   // YYYY-MM-DD
  status   String   // P | A | L | H
  note     String?
  createdAt DateTime @default(now())

  @@unique([empId, date])
}

// ─── PAYROLL ──────────────────────────────────
model Payroll {
  id         Int      @id @default(autoincrement())
  empId      Int      @unique
  employee   Employee @relation(fields: [empId], references: [id])
  month      Int
  year       Int
  basic      Int
  allowance  Int      @default(0)
  overtime   Int      @default(0)
  deduction  Int      @default(0)
  bpjsHealth Int      @default(0)
  bpjsTk     Int      @default(0)
  pph21      Int      @default(0)
  paid       Boolean  @default(false)
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
